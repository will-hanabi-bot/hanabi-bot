# Login information for each bot account on hanab.live
export HANABI_USERNAME1=
export HANABI_PASSWORD1=

export HANABI_USERNAME2=
export HANABI_PASSWORD2=

# when 1 the bot will leave lobby tables when every player appears to be a bot
export HANABI_LEAVE_PREGAME_IF_ONLY_BOTS=0

# when 1 the bot will leave replay views when every spectator appears to be a bot
export HANABI_LEAVE_REPLAY_IF_ONLY_BOTS=1

# comma-separated list of recognised bot name prefixes, e.g. "will-bot" or
# "will-bot,mybot".  Leave empty to disable detection.
export HANABI_BOT_NAME_PREFIXES=
